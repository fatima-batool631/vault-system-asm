INCLUDE C:\irvine\Irvine32.inc
INCLUDELIB C:\irvine\Irvine32.lib
INCLUDELIB C:\irvine\kernel32.lib
INCLUDELIB C:\irvine\user32.lib

EXTERN header:AccountHeader
EXTERN items:Item
EXTERN txtFiles:TxtFile
EXTERN dirtyFlag:DWORD
EXTERN isAuthenticated:DWORD

EXTERN CopyBlock:PROC
EXTERN XorBuffer:PROC

EMAIL_SIZE      EQU 64
NAME_SIZE       EQU 64
NOTES_SIZE      EQU 128
PATH_SIZE       EQU 128
MAX_ITEMS       EQU 100
MAX_TXT_FILES   EQU 50

AccountHeader STRUCT
    email           BYTE EMAIL_SIZE DUP(?)
    pin             DWORD ?
    backupCode      DWORD ?
    itemCount       DWORD ?
    txtCount        DWORD ?
    pinAttempts     DWORD ?
    backupAttempts  DWORD ?
    reserved        BYTE 16 DUP(?)
AccountHeader ENDS

Item STRUCT
    id              DWORD ?
    name            BYTE NAME_SIZE DUP(?)
    quantity        DWORD ?
    notes           BYTE NOTES_SIZE DUP(?)
Item ENDS

TxtFile STRUCT
    fileID          DWORD ?
    filename        BYTE NAME_SIZE DUP(?)
    path            BYTE PATH_SIZE DUP(?)
    linkedID        DWORD ?
TxtFile ENDS

HEADER_SIZE     EQU SIZE AccountHeader
ITEM_SIZE       EQU SIZE Item
TXTFILE_SIZE    EQU SIZE TxtFile

GENERIC_WRITE   EQU 40000000h
GENERIC_READ    EQU 80000000h
CREATE_ALWAYS   EQU 2
OPEN_EXISTING   EQU 3
FILE_ATTRIBUTE_NORMAL EQU 80h
INVALID_HANDLE  EQU 0FFFFFFFFh

.data

vaultFileName   BYTE "vault.dat", 0
msgSaveOk       BYTE "Vault saved successfully.", 0
msgSaveFail     BYTE "Error: Could not save vault.", 0
msgLoadOk       BYTE "Vault loaded successfully.", 0
msgLoadFail     BYTE "Error: Could not open vault file.", 0
msgReadFail     BYTE "Error: Vault file is corrupted.", 0

fileHandle      DWORD 0
bytesWritten    DWORD 0
bytesRead       DWORD 0

tempBuffer      BYTE HEADER_SIZE DUP(0)

.code

_SaveVault PROC
    PUSH EBP
    MOV EBP, ESP
    PUSH EBX
    PUSH ESI
    PUSH EDI

    INVOKE CreateFile,
        OFFSET vaultFileName,
        GENERIC_WRITE,
        0,
        0,
        CREATE_ALWAYS,
        FILE_ATTRIBUTE_NORMAL,
        0

    CMP EAX, INVALID_HANDLE
    JE @@saveFail

    MOV fileHandle, EAX

    MOV ESI, OFFSET header
    MOV ECX, HEADER_SIZE

    PUSH HEADER_SIZE
    PUSH OFFSET header
    CALL XorBuffer

    INVOKE WriteFile,
        fileHandle,
        OFFSET header,
        HEADER_SIZE,
        OFFSET bytesWritten,
        0

    CMP EAX, 0
    JE @@closeAndFail

    PUSH HEADER_SIZE
    PUSH OFFSET header
    CALL XorBuffer

    MOV EAX, [OFFSET header + 72]
    CMP EAX, 0
    JE @@writeTxt

    PUSH ITEM_SIZE
    PUSH OFFSET items
    CALL XorBuffer

    MOV EAX, [OFFSET header + 72]
    MOV EBX, ITEM_SIZE
    MUL EBX

    INVOKE WriteFile,
        fileHandle,
        OFFSET items,
        EAX,
        OFFSET bytesWritten,
        0

    CMP EAX, 0
    JE @@closeAndFail

    MOV EAX, [OFFSET header + 72]
    MOV EBX, ITEM_SIZE
    MUL EBX

    PUSH EAX
    PUSH OFFSET items
    CALL XorBuffer

@@writeTxt:
    MOV EAX, [OFFSET header + 76]
    CMP EAX, 0
    JE @@closeSuccess

    MOV EAX, [OFFSET header + 76]
    MOV EBX, TXTFILE_SIZE
    MUL EBX

    PUSH EAX
    PUSH OFFSET txtFiles
    CALL XorBuffer

    MOV EAX, [OFFSET header + 76]
    MOV EBX, TXTFILE_SIZE
    MUL EBX

    INVOKE WriteFile,
        fileHandle,
        OFFSET txtFiles,
        EAX,
        OFFSET bytesWritten,
        0

    CMP EAX, 0
    JE @@closeAndFail

    MOV EAX, [OFFSET header + 76]
    MOV EBX, TXTFILE_SIZE
    MUL EBX

    PUSH EAX
    PUSH OFFSET txtFiles
    CALL XorBuffer

@@closeSuccess:
    INVOKE CloseHandle, fileHandle
    MOV fileHandle, 0
    MOV dirtyFlag, 0

    MOV EDX, OFFSET msgSaveOk
    CALL WriteString
    CALL Crlf

    MOV EAX, 1
    JMP @@ret

@@closeAndFail:
    INVOKE CloseHandle, fileHandle
    MOV fileHandle, 0

@@saveFail:
    MOV EDX, OFFSET msgSaveFail
    CALL WriteString
    CALL Crlf
    XOR EAX, EAX

@@ret:
    POP EDI
    POP ESI
    POP EBX
    POP EBP
    RET
_SaveVault ENDP

_LoadVault PROC
    PUSH EBP
    MOV EBP, ESP
    PUSH EBX
    PUSH ESI
    PUSH EDI

    INVOKE CreateFile,
        OFFSET vaultFileName,
        GENERIC_READ,
        0,
        0,
        OPEN_EXISTING,
        FILE_ATTRIBUTE_NORMAL,
        0

    CMP EAX, INVALID_HANDLE
    JE @@loadFail

    MOV fileHandle, EAX

    INVOKE ReadFile,
        fileHandle,
        OFFSET header,
        HEADER_SIZE,
        OFFSET bytesRead,
        0

    CMP EAX, 0
    JE @@loadReadFail

    CMP bytesRead, HEADER_SIZE
    JNE @@loadReadFail

    PUSH HEADER_SIZE
    PUSH OFFSET header
    CALL XorBuffer

    MOV EAX, [OFFSET header + 72]
    CMP EAX, 0
    JE @@loadTxt

    MOV EAX, [OFFSET header + 72]
    MOV EBX, ITEM_SIZE
    MUL EBX

    INVOKE ReadFile,
        fileHandle,
        OFFSET items,
        EAX,
        OFFSET bytesRead,
        0

    CMP EAX, 0
    JE @@loadReadFail

    MOV EAX, [OFFSET header + 72]
    MOV EBX, ITEM_SIZE
    MUL EBX

    CMP bytesRead, EAX
    JNE @@loadReadFail

    PUSH bytesRead
    PUSH OFFSET items
    CALL XorBuffer

@@loadTxt:
    MOV EAX, [OFFSET header + 76]
    CMP EAX, 0
    JE @@loadSuccess

    MOV EAX, [OFFSET header + 76]
    MOV EBX, TXTFILE_SIZE
    MUL EBX

    INVOKE ReadFile,
        fileHandle,
        OFFSET txtFiles,
        EAX,
        OFFSET bytesRead,
        0

    CMP EAX, 0
    JE @@loadReadFail

    MOV EAX, header.txtCount
    MOV EBX, TXTFILE_SIZE
    MUL EBX

    CMP bytesRead, EAX
    JNE @@loadReadFail

    PUSH bytesRead
    PUSH OFFSET txtFiles
    CALL XorBuffer

@@loadSuccess:
    INVOKE CloseHandle, fileHandle
    MOV fileHandle, 0

    MOV EDX, OFFSET msgLoadOk
    CALL WriteString
    CALL Crlf

    MOV EAX, 1
    JMP @@ret

@@loadReadFail:
    INVOKE CloseHandle, fileHandle
    MOV fileHandle, 0

    MOV EDX, OFFSET msgReadFail
    CALL WriteString
    CALL Crlf
    XOR EAX, EAX
    JMP @@ret

@@loadFail:
    MOV EDX, OFFSET msgLoadFail
    CALL WriteString
    CALL Crlf
    XOR EAX, EAX

@@ret:
    POP EDI
    POP ESI
    POP EBX
    POP EBP
    RET
_LoadVault ENDP

VaultFileExists PROC
    PUSH EBP
    MOV EBP, ESP

    INVOKE CreateFile,
        OFFSET vaultFileName,
        GENERIC_READ,
        0,
        0,
        OPEN_EXISTING,
        FILE_ATTRIBUTE_NORMAL,
        0

    CMP EAX, INVALID_HANDLE
    JE @@notFound

    INVOKE CloseHandle, EAX
    MOV EAX, 1
    JMP @@ret

@@notFound:
    XOR EAX, EAX

@@ret:
    POP EBP
    RET
VaultFileExists ENDP

PUBLIC _SaveVault
PUBLIC _LoadVault
PUBLIC VaultFileExists

END