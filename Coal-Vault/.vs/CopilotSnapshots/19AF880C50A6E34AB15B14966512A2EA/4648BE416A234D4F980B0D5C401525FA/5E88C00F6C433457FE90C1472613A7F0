INCLUDE Irvine32.inc

EMAIL_SIZE      EQU 64
NAME_SIZE       EQU 64
NOTES_SIZE      EQU 128
PATH_SIZE       EQU 128
MAX_ITEMS       EQU 100
MAX_TXT_FILES   EQU 50

AccountHeader STRUCT
    email           BYTE EMAIL_SIZE DUP(?)
    pin             DWORD ?
    backupCode      DWORD ?
    itemCount       DWORD ?
    txtCount        DWORD ?
    pinAttempts     DWORD ?
    backupAttempts  DWORD ?
    reserved        BYTE 16 DUP(?)
AccountHeader ENDS

Item STRUCT
    id          DWORD ?
    name        BYTE NAME_SIZE DUP(?)
    quantity    DWORD ?
    notes       BYTE NOTES_SIZE DUP(?)
Item ENDS

TxtFile STRUCT
    fileID      DWORD ?
    filename    BYTE NAME_SIZE DUP(?)
    path        BYTE PATH_SIZE DUP(?)
    linkedID    DWORD ?
TxtFile ENDS

.DATA
    testName        BYTE "Test Item", 0
    testNotes       BYTE "This is a test note", 0
    testFilename    BYTE "testfile.txt", 0
    testPath        BYTE "C:\vault\testfile.txt", 0

    headerMsg       BYTE "=== VAULT DATA TEST ===", 0Dh, 0Ah, 0
    idMsg           BYTE "Item ID: ", 0
    nameMsg         BYTE "Item Name: ", 0
    quantityMsg     BYTE "Item Quantity: ", 0
    notesMsg        BYTE "Item Notes: ", 0
    fileIdMsg       BYTE "File ID: ", 0
    separator       BYTE "---", 0Dh, 0Ah, 0

    header          AccountHeader <>
    items           Item MAX_ITEMS DUP(<>)
    txtFiles        TxtFile MAX_TXT_FILES DUP(<>)

.CODE
main PROC
    call Clrscr

    mov edx, OFFSET headerMsg
    call WriteString

    mov eax, 1
    mov DWORD PTR [OFFSET items + 0], eax

    mov eax, 5
    mov DWORD PTR [OFFSET items + 68], eax

    mov edx, OFFSET idMsg
    call WriteString
    mov eax, DWORD PTR [OFFSET items + 0]
    call WriteDec
    call Crlf

    mov edx, OFFSET quantityMsg
    call WriteString
    mov eax, DWORD PTR [OFFSET items + 68]
    call WriteDec
    call Crlf

    mov edx, OFFSET separator
    call WriteString

    mov eax, 101
    mov DWORD PTR [OFFSET txtFiles + 0], eax

    mov eax, 1
    mov DWORD PTR [OFFSET txtFiles + 196], eax

    mov edx, OFFSET fileIdMsg
    call WriteString
    mov eax, DWORD PTR [OFFSET txtFiles + 0]
    call WriteDec
    call Crlf

    call WaitMsg
    exit
main ENDP

END main
