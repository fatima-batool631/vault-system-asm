; ============================================================
;  vault_items.asm  -  Item Management Module
;  Vault Management System  |  COAL Project
;  Platform  : Win32 (x86), MASM, Irvine32
;  Convention: stdcall  |  Return value : EAX
; ============================================================
;  Exported Procedures
;    _AddItem    (namePtr:PTR BYTE, quantity:DWORD, notesPtr:PTR BYTE)
;    _DeleteItem (itemID:DWORD)
;    _SearchItem (namePtr:PTR BYTE)
; ============================================================

    INCLUDE Irvine32.inc

; ---------------------------------------------------------------
; External symbols  (defined in vault_data.asm)
; ---------------------------------------------------------------
EXTERN header    : BYTE         ; AccountHeader struct instance
EXTERN items     : BYTE         ; Item array  [MAX_ITEMS]
EXTERN dirtyFlag : DWORD

; ---------------------------------------------------------------
; Constants  (must match vault_data.asm)
; ---------------------------------------------------------------
NAME_SIZE   EQU 64
NOTES_SIZE  EQU 128
MAX_ITEMS   EQU 100

; Item struct layout (total = 200 bytes)
;   id        DWORD  @ +0
;   name      BYTE64 @ +4
;   quantity  DWORD  @ +68
;   notes     BYTE128@ +72
ITEM_SIZE       EQU 200
ITEM_ID_OFF     EQU 0
ITEM_NAME_OFF   EQU 4
ITEM_QTY_OFF    EQU 68
ITEM_NOTES_OFF  EQU 72

; AccountHeader offsets we need:
;   email(64) + pin(4) + backupCode(4) = itemCount at +72
HDR_ITEMCOUNT   EQU 72

; ---------------------------------------------------------------
; Scratch variable in .data (used by _DeleteItem shift loop)
; ---------------------------------------------------------------
.data
srcAddr     DWORD 0

; ===============================================================
.code

; ---------------------------------------------------------------
; HELPER  CopyStringFixed
; Copies a null-terminated string ESI -> EDI (exactly ECX bytes).
; Zero-pads the remainder of the destination.
; Clobbers: EAX, ECX, ESI, EDI  (caller does PUSHAD)
; ---------------------------------------------------------------
CopyStringFixed PROC
    CLD
CFS_Loop:
    TEST ECX, ECX
    JZ   CFS_Done
    MOV  AL, [ESI]
    MOV  [EDI], AL
    INC  ESI
    INC  EDI
    DEC  ECX
    TEST AL, AL
    JZ   CFS_Pad           ; null byte written -> pad rest
    JMP  CFS_Loop
CFS_Pad:
    XOR  AL, AL
    REP  STOSB              ; zero remaining ECX bytes
CFS_Done:
    RET
CopyStringFixed ENDP


; ---------------------------------------------------------------
; HELPER  CompareStrings
; Compares null-terminated strings at ESI and EDI.
; Returns EAX = 1 (equal) | 0 (not equal)
; Clobbers: EAX, ESI, EDI  (caller does PUSHAD + saves EBX/ECX)
; ---------------------------------------------------------------
CompareStrings PROC
    CLD
CS_Loop:
    MOV  AL, [ESI]
    MOV  AH, [EDI]
    CMP  AL, AH
    JNE  CS_NotEq
    TEST AL, AL            ; both chars are equal - are we at end?
    JZ   CS_Equal          ; yes -> match
    INC  ESI
    INC  EDI
    JMP  CS_Loop
CS_Equal:
    MOV  EAX, 1
    RET
CS_NotEq:
    XOR  EAX, EAX
    RET
CompareStrings ENDP


; ---------------------------------------------------------------
; HELPER  GetItemPtr
; Returns pointer to items[EBX] in EAX.
; Input : EBX = zero-based index
; Output: EAX = address of items[EBX]
; Clobbers: EAX, EDX
; ---------------------------------------------------------------
GetItemPtr PROC
    MOV  EAX, ITEM_SIZE
    MUL  EBX               ; EAX = index * ITEM_SIZE  (unsigned)
    ADD  EAX, OFFSET items ; EAX = base + offset
    RET
GetItemPtr ENDP


; ===============================================================
;  _AddItem
;
;  Appends a new item to the items[] array.
;
;  Stack (stdcall):
;    [EBP+ 8]  namePtr  : PTR BYTE  (null-terminated, <= 63 chars)
;    [EBP+12]  quantity : DWORD
;    [EBP+16]  notesPtr : PTR BYTE  (null-terminated, <=127 chars)
;
;  Returns EAX:
;    new item ID (1-based)    on success
;    0                        vault is full
; ===============================================================
_AddItem PROC
    PUSH EBP
    MOV  EBP, ESP
    PUSHAD                  ; saves all GP registers; EAX slot at [ESP+28]

    ; --- guard: full? ---------------------------------------
    MOV  EBX, [header + HDR_ITEMCOUNT]
    CMP  EBX, MAX_ITEMS
    JGE  AddItem_Full

    ; --- &items[index] --------------------------------------
    CALL GetItemPtr         ; EAX = address
    MOV  EDI, EAX

    ; --- assign ID ------------------------------------------
    MOV  EAX, EBX
    INC  EAX                ; 1-based ID
    MOV  [EDI + ITEM_ID_OFF], EAX
    PUSH EAX                ; save new ID for return

    ; --- copy name ------------------------------------------
    MOV  ESI, [EBP+8]
    LEA  EDI, [EDI + ITEM_NAME_OFF]
    MOV  ECX, NAME_SIZE
    CALL CopyStringFixed

    ; --- reload base ptr (EDI was advanced by CopyStringFixed)
    MOV  EBX, [header + HDR_ITEMCOUNT]
    CALL GetItemPtr
    MOV  EDI, EAX

    ; --- store quantity -------------------------------------
    MOV  EAX, [EBP+12]
    MOV  [EDI + ITEM_QTY_OFF], EAX

    ; --- copy notes -----------------------------------------
    MOV  ESI, [EBP+16]
    LEA  EDI, [EDI + ITEM_NOTES_OFF]
    MOV  ECX, NOTES_SIZE
    CALL CopyStringFixed

    ; --- commit ---------------------------------------------
    INC  DWORD PTR [header + HDR_ITEMCOUNT]
    MOV  dirtyFlag, 1

    ; --- return new ID (was pushed before copying name) -----
    POP  EAX
    MOV  [ESP + 28], EAX    ; patch PUSHAD's saved-EAX slot
    POPAD
    MOV  ESP, EBP
    POP  EBP
    RET  12

AddItem_Full:
    MOV  DWORD PTR [ESP + 28], 0
    POPAD
    MOV  ESP, EBP
    POP  EBP
    RET  12
_AddItem ENDP


; ===============================================================
;  _DeleteItem
;
;  Finds the item by ID, removes it, and shifts the array left.
;  Resequences IDs of shifted records.
;
;  Stack:
;    [EBP+8]  itemID : DWORD  (1-based)
;
;  Returns EAX:
;    1    success
;    0    item not found
; ===============================================================
_DeleteItem PROC
    PUSH EBP
    MOV  EBP, ESP
    PUSHAD

    MOV  ECX, [header + HDR_ITEMCOUNT]
    TEST ECX, ECX
    JZ   Del_NotFound       ; empty vault

    ; --- find target index ----------------------------------
    MOV  EDX, [EBP+8]       ; EDX = target ID
    XOR  EBX, EBX           ; EBX = search index

Del_FindLoop:
    CMP  EBX, ECX
    JGE  Del_NotFound

    CALL GetItemPtr
    MOV  EDI, EAX
    CMP  [EDI + ITEM_ID_OFF], EDX
    JE   Del_Shift
    INC  EBX
    JMP  Del_FindLoop

Del_Shift:
    ; EBX = delete index | ECX = itemCount
    ; Shift items[EBX+1 .. ECX-1] one slot to the left
    MOV  ESI, EBX           ; ESI = loop index (starts at delete pos)
    MOV  EDX, ECX
    DEC  EDX                ; EDX = last valid index (itemCount - 1)

Del_ShiftLoop:
    CMP  ESI, EDX
    JGE  Del_ShiftDone      ; nothing more to shift

    ; destination: &items[ESI]
    MOV  EBX, ESI
    CALL GetItemPtr
    MOV  EDI, EAX           ; dest

    ; source: &items[ESI+1]
    MOV  EBX, ESI
    INC  EBX
    CALL GetItemPtr
    MOV  srcAddr, EAX       ; stash source addr

    ; REP MOVSB copies ITEM_SIZE bytes src -> dest
    PUSH ECX
    PUSH ESI
    MOV  ESI, srcAddr
    MOV  ECX, ITEM_SIZE
    CLD
    REP  MOVSB
    POP  ESI
    POP  ECX

    ; fix sequential ID of the just-moved record
    MOV  EBX, ESI
    CALL GetItemPtr
    MOV  EDI, EAX
    MOV  EAX, ESI
    INC  EAX                ; new ID = new index + 1
    MOV  [EDI + ITEM_ID_OFF], EAX

    INC  ESI
    JMP  Del_ShiftLoop

Del_ShiftDone:
    DEC  DWORD PTR [header + HDR_ITEMCOUNT]
    MOV  dirtyFlag, 1
    MOV  DWORD PTR [ESP + 28], 1
    POPAD
    MOV  ESP, EBP
    POP  EBP
    RET  4

Del_NotFound:
    MOV  DWORD PTR [ESP + 28], 0
    POPAD
    MOV  ESP, EBP
    POP  EBP
    RET  4
_DeleteItem ENDP


; ===============================================================
;  _SearchItem
;
;  Linear search by item name (case-sensitive).
;
;  Stack:
;    [EBP+8]  namePtr : PTR BYTE  (null-terminated key)
;
;  Returns EAX:
;    pointer to matching Item struct    found
;    0                                  not found
; ===============================================================
_SearchItem PROC
    PUSH EBP
    MOV  EBP, ESP
    PUSHAD

    MOV  ECX, [header + HDR_ITEMCOUNT]
    TEST ECX, ECX
    JZ   Srch_NotFound

    XOR  EBX, EBX           ; EBX = loop index

Srch_Loop:
    CMP  EBX, ECX
    JGE  Srch_NotFound

    CALL GetItemPtr         ; EAX = &items[EBX]
    MOV  EDI, EAX
    ADD  EDI, ITEM_NAME_OFF ; EDI -> items[EBX].name

    MOV  ESI, [EBP+8]       ; ESI = search key

    PUSH EBX
    PUSH ECX
    CALL CompareStrings     ; EAX = 1 if equal
    POP  ECX
    POP  EBX

    TEST EAX, EAX
    JNZ  Srch_Found

    INC  EBX
    JMP  Srch_Loop

Srch_Found:
    CALL GetItemPtr         ; EAX = &items[EBX]
    MOV  [ESP + 28], EAX    ; patch return value
    POPAD
    MOV  ESP, EBP
    POP  EBP
    RET  4

Srch_NotFound:
    MOV  DWORD PTR [ESP + 28], 0
    POPAD
    MOV  ESP, EBP
    POP  EBP
    RET  4
_SearchItem ENDP

; ---------------------------------------------------------------
; Public exports
; ---------------------------------------------------------------
PUBLIC _AddItem
PUBLIC _DeleteItem
PUBLIC _SearchItem

END